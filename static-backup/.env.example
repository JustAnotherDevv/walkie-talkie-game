# Copy this file to .env.local and fill in values to enable live ElevenLabs
# Conversational AI. Leaving them empty keeps the service on its internal
# mock path (useful for local dev and CI).

# ElevenLabs Conversational AI agent ID (create one at
# https://elevenlabs.io/app/conversational-ai). Must be a public agent or
# one whose signed URL exchange you handle separately.
VITE_ELEVENLABS_AGENT_ID=

# Voice ID generated by scripts/generate-voice.mjs. The live session uses
# this as the TTS voice override when present.
VITE_ELEVENLABS_VOICE_ID=

# API key used ONLY by scripts/generate-*.mjs at build time (not shipped to
# the browser for runtime calls — those go through the agent config).
# Populate this when you run the generation scripts.
ELEVENLABS_API_KEY=
